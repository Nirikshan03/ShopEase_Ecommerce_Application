# ─────────────────────────────────────────────────────────────
# ShopEase Backend — Environment Variables
# Set these in Render Dashboard → Environment tab
# DO NOT commit real values to GitHub
# ─────────────────────────────────────────────────────────────

# Get these 3 values from Aiven.io → Your MySQL Service → Connection Info
SPRING_DATASOURCE_URL=jdbc:mysql://<aiven-host>:<port>/defaultdb?sslMode=REQUIRED&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=avnadmin
SPRING_DATASOURCE_PASSWORD=your_aiven_password

# Any long random string — used to sign JWT tokens
JWT_SECRET=ShopEase2024SecureLongRandomStringReplaceThis

# Your Netlify frontend URL (set after Netlify deploy)
ALLOWED_ORIGIN=https://your-app.netlify.app

# Render sets PORT automatically — do not set this manually
# PORT=8080
